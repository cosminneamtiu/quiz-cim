# Ignore everything by default. This repo only publishes the runnable quiz app.
*

# Allow Git to discover explicitly kept files in subfolders.
!*/

# Repository docs/config.
!.gitattributes
!.gitignore
!README.md
!run.bat

# Runnable quiz app.
!quiz_site/README.md
!quiz_site/index.html
!quiz_site/styles.css
!quiz_site/quiz-data.js
!quiz_site/app.js
